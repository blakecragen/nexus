# Nexus Control Plane Configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=nexus
POSTGRES_USER=nexus

# Redis
REDIS_URL=redis://redis:6379

# MinIO (default storage backend)
MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=changeme_minio

# API Server
DATABASE_URL=postgresql+asyncpg://nexus:changeme_postgres@postgres:5432/nexus
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
CORS_ORIGINS=http://localhost:3000

# Credential encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
